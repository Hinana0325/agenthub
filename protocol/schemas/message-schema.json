{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentcontrolcenter.dev/protocol/schemas/message-schema.json",
  "title": "Agent Control Center Message Schema",
  "description": "聊天消息模型契约。Message 隶属于 Session，包含角色、内容、状态和可选附件。",
  "type": "object",
  "definitions": {
    "MessageRole": {
      "title": "MessageRole",
      "type": "string",
      "enum": ["User", "Assistant", "System", "Tool"],
      "description": "消息角色。注意：HTTP API 中使用小写（user/assistant/system/tool），WebSocket 中使用枚举名首字母大写（User）。两端序列化时需做映射。"
    },
    "MessageStatus": {
      "title": "MessageStatus",
      "type": "string",
      "enum": ["Sending", "Sent", "Received", "Failed"],
      "description": "消息投递状态"
    },
    "AttachmentType": {
      "title": "AttachmentType",
      "type": "string",
      "enum": ["image", "file"],
      "description": "附件类型"
    },
    "Message": {
      "title": "Message",
      "type": "object",
      "required": ["id", "sessionId", "role", "content", "timestamp", "status"],
      "properties": {
        "id": { "type": "string", "description": "消息唯一标识" },
        "sessionId": { "type": "string", "description": "所属会话 ID" },
        "role": { "$ref": "#/definitions/MessageRole" },
        "content": { "type": "string", "description": "消息文本内容" },
        "timestamp": { "type": "integer", "format": "int64", "description": "时间戳（Unix 毫秒）" },
        "status": { "$ref": "#/definitions/MessageStatus" },
        "metadataJson": {
          "type": "string",
          "description": "JSON 格式的扩展元数据，默认 '{}'。存储 token 数、模型名等额外信息",
          "default": "{}"
        },
        "attachmentType": {
          "description": "附件类型（可选）",
          "oneOf": [
            { "$ref": "#/definitions/AttachmentType" },
            { "type": "null" }
          ],
          "default": null
        },
        "attachmentData": {
          "type": ["string", "null"],
          "description": "附件数据。图片：Base64 编码（压缩后最大边 720px，JPEG quality 85）；文件：Base64 或本地路径。大小上限 10MB（压缩前）",
          "default": null
        },
        "attachmentName": {
          "type": ["string", "null"],
          "description": "附件显示名称",
          "default": null
        },
        "reaction": {
          "type": "string",
          "description": "表情回应（emoji 字符串，如 👍）",
          "default": ""
        },
        "replyToId": {
          "type": ["string", "null"],
          "description": "回复的目标消息 ID（可选）",
          "default": null
        }
      }
    }
  }
}
