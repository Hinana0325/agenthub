# Release keystore credentials template.
# Copy this file to keystore.properties and fill in real values.
# keystore.properties is gitignored and will NOT be committed.
#
# CI: values are injected via environment variables (see build.gradle):
#   KEYSTORE_PASSWORD, KEY_ALIAS, KEY_PASSWORD

storeFile=agentcontrolcenter.keystore
storePassword=YOUR_STORE_PASSWORD_HERE
keyAlias=agentcontrolcenter
keyPassword=YOUR_KEY_PASSWORD_HERE
