<?xml version="1.0" encoding="utf-8"?>
<!--
  网络安全配置：
  - 默认禁止明文流量（cleartextTrafficPermitted=false），所有连接强制 TLS
  - 仅对下列本地模型端点开放明文 HTTP（本地回环/局域网，不经公网）：
    127.0.0.1 / localhost / 10.0.2.2（模拟器）/ 10.0.3.2
    以及常见局域网网关地址 10.0.0.1~10、192.168.0.1~10、192.168.1.1~10
  - 注意：NSC 按主机名精确匹配，不支持 CIDR 网段匹配；上述条目仅匹配对应具体主机，
    若需覆盖其他局域网地址请显式追加 <domain>。
    本配置仅覆盖最常见的局域网地址，无法穷举所有可能的内网 IP，
    如需访问其他内网地址（如 172.16.x.x、10.0.1.x 等）请在此显式追加。
  - 用户安装的 CA 证书仅在调试构建中信任
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- 本地模型端点（Ollama / LM Studio / llama.cpp 等）允许明文 HTTP -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">10.0.3.2</domain>
        <!-- 10.0.0.x 常见局域网地址（仅覆盖 1~10，NSC 不支持 CIDR） -->
        <domain includeSubdomains="false">10.0.0.1</domain>
        <domain includeSubdomains="false">10.0.0.2</domain>
        <domain includeSubdomains="false">10.0.0.3</domain>
        <domain includeSubdomains="false">10.0.0.4</domain>
        <domain includeSubdomains="false">10.0.0.5</domain>
        <domain includeSubdomains="false">10.0.0.6</domain>
        <domain includeSubdomains="false">10.0.0.7</domain>
        <domain includeSubdomains="false">10.0.0.8</domain>
        <domain includeSubdomains="false">10.0.0.9</domain>
        <domain includeSubdomains="false">10.0.0.10</domain>
        <!-- 192.168.0.x 常见局域网地址（仅覆盖 1~10，NSC 不支持 CIDR） -->
        <domain includeSubdomains="false">192.168.0.1</domain>
        <domain includeSubdomains="false">192.168.0.2</domain>
        <domain includeSubdomains="false">192.168.0.3</domain>
        <domain includeSubdomains="false">192.168.0.4</domain>
        <domain includeSubdomains="false">192.168.0.5</domain>
        <domain includeSubdomains="false">192.168.0.6</domain>
        <domain includeSubdomains="false">192.168.0.7</domain>
        <domain includeSubdomains="false">192.168.0.8</domain>
        <domain includeSubdomains="false">192.168.0.9</domain>
        <domain includeSubdomains="false">192.168.0.10</domain>
        <!-- 192.168.1.x 常见局域网地址（仅覆盖 1~10，NSC 不支持 CIDR） -->
        <domain includeSubdomains="false">192.168.1.1</domain>
        <domain includeSubdomains="false">192.168.1.2</domain>
        <domain includeSubdomains="false">192.168.1.3</domain>
        <domain includeSubdomains="false">192.168.1.4</domain>
        <domain includeSubdomains="false">192.168.1.5</domain>
        <domain includeSubdomains="false">192.168.1.6</domain>
        <domain includeSubdomains="false">192.168.1.7</domain>
        <domain includeSubdomains="false">192.168.1.8</domain>
        <domain includeSubdomains="false">192.168.1.9</domain>
        <domain includeSubdomains="false">192.168.1.10</domain>
        <domain includeSubdomains="false">localhost</domain>
        <!-- IPv6 本地回环 -->
        <domain includeSubdomains="false">ip6-localhost</domain>
    </domain-config>

    <!-- 调试构建额外信任用户安装的 CA（用于代理抓包调试） -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
