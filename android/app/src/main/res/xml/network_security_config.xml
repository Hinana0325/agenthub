<?xml version="1.0" encoding="utf-8"?>
<!--
  网络安全配置（M-2 收紧）：
  - 默认禁止明文流量（cleartextTrafficPermitted=false），所有连接强制 TLS
  - release 构建（base domain-config）仅保留本地回环：
    127.0.0.1 / localhost / ip6-localhost
    （本地 Ollama / LM Studio 等本地模型端点需要明文 HTTP）
  - 模拟器专用地址 10.0.2.2 / 10.0.3.2 移到 <debug-overrides> 中，
    仅 debug 构建放行（这些地址只在 Android 模拟器上映射宿主机，真机无意义）
  - 删除路由器/局域网网关 IP（192.168.0.x / 192.168.1.x / 10.0.0.x），
    避免在 release 构建中放行过多内网明文目标
  - 用户安装的 CA 证书仅在调试构建中信任
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- 本地模型端点（Ollama / LM Studio / llama.cpp 等）允许明文 HTTP -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
        <!-- IPv6 本地回环 -->
        <domain includeSubdomains="false">ip6-localhost</domain>
    </domain-config>

    <!-- 调试构建额外信任用户安装的 CA（用于代理抓包调试） +
         模拟器专用明文地址（10.0.2.2 / 10.0.3.2 映射宿主机回环） -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
        <domain-config cleartextTrafficPermitted="true">
            <domain includeSubdomains="false">10.0.2.2</domain>
            <domain includeSubdomains="false">10.0.3.2</domain>
        </domain-config>
    </debug-overrides>
</network-security-config>
